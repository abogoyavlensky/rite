(ns rite.style
  (:require [string :as str]))

;; --------------------------------------------------------------------------
;; Styled status output
;;
;; rite prints a short status header before each task and step. Task headers
;; and step lines are decoration: callers write the returned strings to *err*
;; (stdout is reserved for the program's real output). These fns are pure so
;; they stay testable.
;;
;; let-go has no TTY detection, so color cannot be auto-disabled when piped.
;; The only gate is RITE_NO_COLOR (named with the project's RITE_ prefix): color
;; is disabled when the var is present and non-empty. os/getenv returns "" for
;; an unset var, so a blank value means color is enabled.
;; --------------------------------------------------------------------------

(defn- color-enabled? []
  (str/blank? (os/getenv "RITE_NO_COLOR")))

(def ^:private green-code 35)   ; emerald — built-in command output
(def ^:private purple-code 98)  ; medium violet — project task output

;; Fixed 256-color cube shades chosen for contrast on both light and dark
;; terminals (green = 35 emerald, purple = 98 medium violet), color only — no
;; bold, since these status lines print on every command and a lighter weight
;; reads calmer for everyday use. Cube colors (not the 0-15 theme palette) so the
;; shade stays stable regardless of the user's color scheme.
(defn- colorize [code s]
  (if (color-enabled?)
    (str "[38;5;" code "m" s "[0m")
    s))

(defn green
  "Wrap s in green (built-in command color), unless RITE_NO_COLOR disables it."
  [s]
  (colorize green-code s))

(defn purple
  "Wrap s in purple (custom task color), unless RITE_NO_COLOR disables it."
  [s]
  (colorize purple-code s))

(defn header
  "Green `=> <text>` status header for a built-in command."
  [text]
  (green (str "=> " text)))

(defn task-header
  "Purple `=> Running task <name>...` header for a custom project task."
  [name]
  (purple (str "=> Running task " name "...")))

(defn step-line
  "`$ <cmd>` line echoing a task step's command before it runs. The `$` is
   purple to tie the step to its task; the command is plain. Callers add a
   leading blank line to separate each step from the previous step's output."
  [cmd]
  (str (purple "$") " " cmd))
