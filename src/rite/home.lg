(ns rite.home
  (:require [rite.path :as path]
            [string :as str]))

(defn root
  "Return the rite state root for the gitlibs cache. RITE_HOME wins; else
   $XDG_CACHE_HOME/rite; else the default ~/.cache/rite."
  []
  (let [rite-home (os/getenv "RITE_HOME")
        xdg-cache (os/getenv "XDG_CACHE_HOME")]
    (cond
      (not (str/blank? rite-home)) rite-home
      (not (str/blank? xdg-cache)) (path/join xdg-cache "rite")
      :else (path/join (os/getenv "HOME") ".cache" "rite"))))
