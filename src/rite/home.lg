(ns rite.home
  (:require [rite.path :as path]
            [string :as str]))

(defn root
  "Return the rite state root for the gitlibs cache. RITE_HOME wins; else
   LGX_HOME (so deps fetched by lgx are reused, and vice versa); else the
   default ~/.lgx."
  []
  (let [rite-home (os/getenv "RITE_HOME")
        lgx-home (os/getenv "LGX_HOME")]
    (cond
      (not (str/blank? rite-home)) rite-home
      (not (str/blank? lgx-home)) lgx-home
      :else (path/join (os/getenv "HOME") ".lgx"))))
