{:paths ["src"]
 :main "main.lg"
 :targets {:bin {:out "bin/rite"}}
 :deps {}
 :tasks {fmt {:doc "Format source files (available actions: fix, check; default: fix)"
              :args [{:name :action
                      :type [:enum "fix" "check"]
                      :default "fix"}]
              :do [{:sh "cljfmt {{action}}"}]}
         
         lint {:doc "Lint source files"
               :do [{:sh "find src test -type f -name '*.lg' -print0 | xargs -0 clj-kondo --lint"}]}
         
         e2e {:doc "Build the bundle and run unit + e2e tests"
              :do [{:sh "bash tests/run.sh"}]}

         check {:doc "Run all checks (fmt, lint, then build + unit + e2e)"
                :do [{:sh "lgx fmt check"}
                     {:sh "lgx lint"}
                     {:sh "bash tests/run.sh"}]}}}
