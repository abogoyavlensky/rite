;; Unit tests for rite.completion — pure TAB-completion candidate logic and the
;; bundled shell scripts.
;; Run with: lgx test  (from project root)

(ns rite.completion-test
  (:require [clojure.test :refer [deftest is]]
            [rite.completion :as completion]
            [string :as str]))

;; A task map like project-tasks produces: task-name string -> :args decls.
;; `fmt` carries a single [:enum ...] arg; `lint` and the namespaced `foo/bar`
;; carry none.
(def sample-tasks
  {"fmt" [{:name :action
           :type [:enum "fix" "check"]
           :default "fix"}]
   "lint" nil
   "foo/bar" nil})

;; ---------------------------------------------------------------------------
;; candidates — command position
;; ---------------------------------------------------------------------------

(deftest command-position-lists-builtins-and-tasks-sorted
  ;; Sorted: "fmt" precedes "foo/bar" (m < o); "tasks" built-in included.
  (is (= ["fmt" "foo/bar" "lint" "tasks"]
         (completion/candidates [] "" sample-tasks))))

(deftest command-position-no-tasks-lists-builtin-only
  (is (= ["tasks"] (completion/candidates [] "" {}))))

(deftest command-position-prefix-filters
  (is (= ["fmt"] (completion/candidates [] "fm" sample-tasks)))
  (is (= ["tasks"] (completion/candidates [] "ta" sample-tasks))))

(deftest command-position-matches-namespaced-task
  ;; "/" is in the shell-safe set, so namespaced names survive.
  (is (= ["foo/bar"] (completion/candidates [] "foo" sample-tasks))))

(deftest command-position-drops-shell-unsafe-task-name
  ;; A task name with a shell metacharacter is never inserted onto the command
  ;; line on TAB; it still runs when typed by hand.
  (let [tasks {"safe" nil
               "a$b" nil}]
    ;; "tasks" built-in is always present; the unsafe name is dropped.
    (is (= ["safe" "tasks"] (completion/candidates [] "" tasks)))
    (is (= [] (completion/candidates [] "a" tasks)))))

(deftest hidden-commands-never-offered
  (let [out (completion/candidates [] "" sample-tasks)]
    (is (not (some #(= "completion" %) out)))
    (is (not (some #(= "__complete" %) out)))))

(deftest leading-verbose-still-completes-command
  (is (= ["fmt"] (completion/candidates ["--verbose"] "fm" sample-tasks))))

;; ---------------------------------------------------------------------------
;; candidates — enum arg values at a task's arg position
;; ---------------------------------------------------------------------------

(deftest enum-values-offered-at-first-arg
  (is (= ["check" "fix"] (completion/candidates ["fmt"] "" sample-tasks))))

(deftest enum-values-prefix-filtered
  (is (= ["fix"] (completion/candidates ["fmt"] "f" sample-tasks))))

(deftest no-enum-decl-yields-nothing
  (is (= [] (completion/candidates ["lint"] "" sample-tasks))))

(deftest past-last-decl-yields-nothing
  (is (= [] (completion/candidates ["fmt" "fix"] "" sample-tasks))))

(deftest unknown-typed-command-yields-nothing
  (is (= [] (completion/candidates ["nope"] "" sample-tasks))))

;; ---------------------------------------------------------------------------
;; candidates — flags are never completed
;; ---------------------------------------------------------------------------

(deftest dash-prefix-never-completes-at-command-position
  (is (= [] (completion/candidates [] "-" sample-tasks)))
  (is (= [] (completion/candidates [] "--" sample-tasks))))

(deftest dash-prefix-never-completes-at-arg-position
  (is (= [] (completion/candidates ["fmt"] "-" sample-tasks))))

;; ---------------------------------------------------------------------------
;; Shell scripts + lookup
;; ---------------------------------------------------------------------------

(deftest bash-script-registers-rite-completion
  (let [s (completion/completion-script "bash")]
    (is (not (str/blank? s)))
    (is (str/includes? s "__complete"))
    (is (str/includes? s "complete -o default"))))

(deftest zsh-script-registers-rite-completion
  (let [s (completion/completion-script "zsh")]
    (is (not (str/blank? s)))
    (is (str/includes? s "__complete"))
    (is (str/includes? s "#compdef rite"))))

(deftest fish-script-registers-rite-completion
  (let [s (completion/completion-script "fish")]
    (is (not (str/blank? s)))
    (is (str/includes? s "__complete"))
    (is (str/includes? s "complete -c rite"))))

(deftest completion-script-unknown-shell-is-nil
  (is (nil? (completion/completion-script "nope"))))
