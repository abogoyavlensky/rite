;; Unit tests for rite.path.
;; Run with: lgx test  (from project root)

(ns rite.path-test
  (:require [clojure.test :refer [deftest is]]
            [rite.path :as path]))

(def sep os/file-separator)

;; ---------------------------------------------------------------------------
;; join
;; ---------------------------------------------------------------------------

(deftest join-two-segments
  (is (= (str "a" sep "b") (path/join "a" "b"))))

(deftest join-variadic
  (is (= (str "a" sep "b" sep "c") (path/join "a" "b" "c"))))

(deftest join-splits-embedded-slashes
  (is (= (str "a" sep "b" sep "c") (path/join "a" "b/c"))))

(deftest join-preserves-absolute
  (is (= (str sep "a" sep "b") (path/join "/a" "b"))))

(deftest join-drops-empty-segments
  (is (= (str "a" sep "b") (path/join "a" "" "b"))))

(deftest join-drops-trailing-slash
  (is (= (str "a" sep "b") (path/join "a" "b/"))))

(deftest join-single-segment
  (is (= "a" (path/join "a")))
  (is (= sep (path/join "/"))))

;; ---------------------------------------------------------------------------
;; parent
;; ---------------------------------------------------------------------------

(deftest parent-strips-last-component
  (is (= (str sep "a" sep "b")
         (path/parent (str sep "a" sep "b" sep "c")))))

(deftest parent-root-returns-nil
  (is (= nil (path/parent sep))))

(deftest parent-no-separator-returns-nil
  (is (= nil (path/parent "abc"))))

(deftest parent-trailing-separator
  (is (= (str sep "a")
         (path/parent (str sep "a" sep "b" sep)))))

(deftest parent-one-level-from-root
  (is (= sep (path/parent (str sep "abc")))))

;; ---------------------------------------------------------------------------
;; absolute?
;; ---------------------------------------------------------------------------

(deftest absolute?-leading-separator
  (is (= true (path/absolute? "/foo/bar"))))

(deftest absolute?-relative
  (is (= false (path/absolute? "foo/bar"))))

(deftest absolute?-empty
  (is (= false (path/absolute? ""))))

(deftest absolute?-root
  (is (= true (path/absolute? "/"))))

;; ---------------------------------------------------------------------------
;; normalize
;; ---------------------------------------------------------------------------

(deftest normalize-drops-dot-segment
  (is (= (str sep "proj" sep "test" sep "foo.lg")
         (path/normalize (str sep "proj" sep "." sep "test" sep "foo.lg")))))

(deftest normalize-resolves-double-dot
  (is (= (str sep "proj" sep "src" sep "foo.lg")
         (path/normalize (str sep "proj" sep "test" sep ".." sep "src" sep "foo.lg")))))

(deftest normalize-relative-paths
  (is (= "test/foo.lg" (path/normalize "./test/foo.lg")))
  (is (= "src/foo.lg" (path/normalize "test/../src/foo.lg"))))

(deftest normalize-preserves-absolute-marker
  (is (= sep (path/normalize sep)))
  (is (= sep (path/normalize (str sep "a" sep "..")))))

(deftest normalize-collapses-redundant-separators
  (is (= (str sep "a" sep "b")
         (path/normalize (str sep "a" sep sep "b")))))
