;; Unit tests for rite.spec — the minimal schema-as-data validation engine.
;; Run with: lgx test  (from project root)

(ns rite.spec-test
  (:require [clojure.test :refer [deftest is]]
            [rite.spec :as spec]))

;; ---------------------------------------------------------------------------
;; Leaf types
;; ---------------------------------------------------------------------------

(deftest leaf-string-accepts-string
  (is (= [] (spec/validate :string "x"))))

(deftest leaf-string-rejects-non-string
  (is (= [{:path []
           :msg "must be a string, got 42"}]
         (spec/validate :string 42))))

(deftest leaf-string-rejects-nil
  (is (= [{:path []
           :msg "must be a string, got nil"}]
         (spec/validate :string nil))))

(deftest leaf-keyword
  (is (= [] (spec/validate :keyword :a)))
  (is (= [{:path []
           :msg "must be a keyword, got \"a\""}]
         (spec/validate :keyword "a"))))

(deftest leaf-symbol
  (is (= [] (spec/validate :symbol 'foo/bar)))
  (is (= [{:path []
           :msg "must be a symbol, got :a"}]
         (spec/validate :symbol :a))))

(deftest leaf-map
  (is (= [] (spec/validate :map {:a 1})))
  (is (= [{:path []
           :msg "must be a map, got [1]"}]
         (spec/validate :map [1]))))

(deftest leaf-vector
  (is (= [] (spec/validate :vector [1])))
  (is (= [{:path []
           :msg "must be a vector, got {:a 1}"}]
         (spec/validate :vector {:a 1}))))

(deftest leaf-any-accepts-everything
  (is (= [] (spec/validate :any 42)))
  (is (= [] (spec/validate :any nil)))
  (is (= [] (spec/validate :any {:a 1}))))

;; ---------------------------------------------------------------------------
;; [:map ...]
;; ---------------------------------------------------------------------------

(deftest map-accepts-valid-entries
  (is (= [] (spec/validate [:map [:a :string]] {:a "x"}))))

(deftest map-rejects-non-map-value
  (is (= [{:path []
           :msg "must be a map, got 42"}]
         (spec/validate [:map [:a :string]] 42))))

(deftest map-reports-missing-required-key
  (is (= [{:path []
           :msg "missing required key :a"}]
         (spec/validate [:map [:a :string]] {}))))

(deftest map-optional-key-may-be-absent
  (is (= [] (spec/validate [:map [:a {:optional true} :string]] {}))))

(deftest map-optional-key-still-validated-when-present
  (is (= [{:path [:a]
           :msg "must be a string, got 1"}]
         (spec/validate [:map [:a {:optional true} :string]] {:a 1}))))

(deftest map-open-by-default
  (is (= [] (spec/validate [:map [:a :string]] {:a "x"
                                                :b 1}))))

(deftest map-closed-rejects-unknown-key
  (is (= [{:path []
           :msg "unknown key :b (allowed: :a)"}]
         (spec/validate [:map {:closed true} [:a :string]] {:a "x"
                                                            :b 1}))))

(deftest map-closed-lists-allowed-keys-in-entry-order
  (is (= [{:path []
           :msg "unknown key :z (allowed: :b, :a)"}]
         (spec/validate [:map {:closed true}
                         [:b {:optional true} :string]
                         [:a {:optional true} :string]]
                        {:z 1}))))

(deftest map-closed-reports-each-unknown-key-sorted
  (is (= [{:path []
           :msg "unknown key :y (allowed: :a)"}
          {:path []
           :msg "unknown key :z (allowed: :a)"}]
         (spec/validate [:map {:closed true} [:a {:optional true} :string]]
                        {:z 1
                         :y 2}))))

(deftest map-nested-paths
  (is (= [{:path [:a :b]
           :msg "must be a string, got 1"}]
         (spec/validate [:map [:a [:map [:b :string]]]]
                        {:a {:b 1}}))))

(deftest map-aggregates-errors-across-entries
  (is (= [{:path [:a]
           :msg "must be a string, got 1"}
          {:path []
           :msg "missing required key :b"}]
         (spec/validate [:map [:a :string] [:b :string]]
                        {:a 1}))))

;; ---------------------------------------------------------------------------
;; [:vector ...]
;; ---------------------------------------------------------------------------

(deftest vector-accepts-valid-items
  (is (= [] (spec/validate [:vector :string] ["a" "b"]))))

(deftest vector-accepts-empty-without-min
  (is (= [] (spec/validate [:vector :string] []))))

(deftest vector-rejects-non-vector
  (is (= [{:path []
           :msg "must be a vector, got \"x\""}]
         (spec/validate [:vector :string] "x"))))

(deftest vector-item-errors-carry-index
  (is (= [{:path [1]
           :msg "must be a string, got 1"}]
         (spec/validate [:vector :string] ["a" 1]))))

(deftest vector-min-one-rejects-empty
  (is (= [{:path []
           :msg "must contain at least 1 element"}]
         (spec/validate [:vector {:min 1} :string] []))))

(deftest vector-min-one-accepts-non-empty
  (is (= [] (spec/validate [:vector {:min 1} :string] ["a"]))))

(deftest vector-nested-in-map
  (is (= [{:path [:paths 1]
           :msg "must be a string, got 2"}]
         (spec/validate [:map [:paths [:vector :string]]]
                        {:paths ["a" 2]}))))

;; ---------------------------------------------------------------------------
;; [:map-of ...]
;; ---------------------------------------------------------------------------

(deftest map-of-accepts-valid-entries
  (is (= [] (spec/validate [:map-of :symbol :map]
                           {'foo/bar {:git/sha "abc"}}))))

(deftest map-of-rejects-non-map-value
  (is (= [{:path []
           :msg "must be a map, got 42"}]
         (spec/validate [:map-of :symbol :map] 42))))

(deftest map-of-key-error-appends-key-to-path
  (is (= [{:path ["k"]
           :msg "must be a symbol, got \"k\""}]
         (spec/validate [:map-of :symbol :map] {"k" {}}))))

(deftest map-of-value-error-appends-key-to-path
  (is (= [{:path ['foo/bar]
           :msg "must be a map, got 42"}]
         (spec/validate [:map-of :symbol :map] {'foo/bar 42}))))

(deftest map-of-nested-path
  (is (= [{:path [:deps 'foo/bar]
           :msg "must be a map, got 42"}]
         (spec/validate [:map [:deps [:map-of :symbol :map]]]
                        {:deps {'foo/bar 42}}))))

;; ---------------------------------------------------------------------------
;; [:or ...]
;; ---------------------------------------------------------------------------

(def ^:private string-or-strings
  [:or {:msg "must be a string or vector of strings"}
   :string
   [:vector :string]])

(deftest or-accepts-first-branch
  (is (= [] (spec/validate string-or-strings "x"))))

(deftest or-accepts-second-branch
  (is (= [] (spec/validate string-or-strings ["a" "b"]))))

(deftest or-reports-single-message-when-all-branches-fail
  (is (= [{:path []
           :msg "must be a string or vector of strings"}]
         (spec/validate string-or-strings 42))))

(deftest or-message-carries-nested-path
  (is (= [{:path [:sh]
           :msg "must be a string or vector of strings"}]
         (spec/validate [:map [:sh string-or-strings]] {:sh 42}))))

;; ---------------------------------------------------------------------------
;; [:and ...]
;; ---------------------------------------------------------------------------

(deftest and-passes-when-all-pass
  (is (= [] (spec/validate [:and :map [:fn (fn [_] nil)]] {:a 1}))))

(deftest and-stops-at-first-failing-schema
  ;; the :fn would report if reached; a non-map must short-circuit before it
  (is (= [{:path []
           :msg "must be a map, got 42"}]
         (spec/validate [:and :map [:fn (fn [_] "fn reached")]] 42))))

(deftest and-reports-second-schema-when-first-passes
  (is (= [{:path []
           :msg "custom rule failed"}]
         (spec/validate [:and :map [:fn (fn [_] "custom rule failed")]]
                        {:a 1}))))

;; ---------------------------------------------------------------------------
;; [:enum ...]
;; ---------------------------------------------------------------------------

(deftest enum-accepts-member
  (is (= [] (spec/validate [:enum :a :b] :a))))

(deftest enum-rejects-non-member
  (is (= [{:path []
           :msg "must be one of: :a, :b, got :c"}]
         (spec/validate [:enum :a :b] :c))))

;; ---------------------------------------------------------------------------
;; [:fn f]
;; ---------------------------------------------------------------------------

(deftest fn-nil-result-is-valid
  (is (= [] (spec/validate [:fn (fn [_] nil)] 42))))

(deftest fn-string-result-is-error-at-current-path
  (is (= [{:path [:a]
           :msg "bad value"}]
         (spec/validate [:map [:a [:fn (fn [_] "bad value")]]]
                        {:a 1}))))

(deftest fn-map-result-path-is-prefixed
  (is (= [{:path [:a :inner]
           :msg "bad inner"}]
         (spec/validate [:map [:a [:fn (fn [_] {:path [:inner]
                                                :msg "bad inner"})]]]
                        {:a 1}))))

(deftest fn-vector-result-yields-multiple-errors
  (is (= [{:path []
           :msg "first"}
          {:path [:sub]
           :msg "second"}]
         (spec/validate [:fn (fn [_] ["first" {:path [:sub]
                                               :msg "second"}])]
                        42))))

(deftest fn-receives-the-value
  (is (= [{:path []
           :msg "got 7"}]
         (spec/validate [:fn (fn [v] (str "got " v))] 7))))

;; ---------------------------------------------------------------------------
;; error->line
;; ---------------------------------------------------------------------------

(deftest error-line-empty-path-renders-message-only
  (is (= "top-level form must be a map"
         (spec/error->line {:path []
                            :msg "top-level form must be a map"}))))

(deftest error-line-keyword-segments
  (is (= ":paths — must be a vector, got \"src\""
         (spec/error->line {:path [:paths]
                            :msg "must be a vector, got \"src\""}))))

(deftest error-line-index-segments
  (is (= ":tasks :build :do [0] — unknown key :shh (allowed: :sh, :run)"
         (spec/error->line {:path [:tasks :build :do 0]
                            :msg "unknown key :shh (allowed: :sh, :run)"}))))

(deftest error-line-symbol-segments
  (is (= ":deps foo/bar — missing :git/url"
         (spec/error->line {:path [:deps 'foo/bar]
                            :msg "missing :git/url"}))))
