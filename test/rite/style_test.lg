;; Unit tests for rite.style.
;; Run with: lgx test  (from project root)

(ns rite.style-test
  (:require [clojure.test :refer [deftest is]]
            [rite.style :as style]))

(def esc "")

;; Each color-dependent test sets RITE_NO_COLOR explicitly and restores it to ""
;; afterward, so test ordering cannot leak the env between cases. os/getenv
;; returns "" for an unset var, so "" is the "color enabled" state.

;; ---------------------------------------------------------------------------
;; green / purple (color enabled)
;; ---------------------------------------------------------------------------

(deftest green-wraps-code-35
  (os/setenv "RITE_NO_COLOR" "")
  (is (= (str esc "[38;5;35mhello" esc "[0m") (style/green "hello"))))

(deftest purple-wraps-code-98
  (os/setenv "RITE_NO_COLOR" "")
  (is (= (str esc "[38;5;98mhello" esc "[0m") (style/purple "hello"))))

;; ---------------------------------------------------------------------------
;; RITE_NO_COLOR disables color
;; ---------------------------------------------------------------------------

(deftest green-plain-when-no-color
  (os/setenv "RITE_NO_COLOR" "1")
  (is (= "hello" (style/green "hello")))
  (os/setenv "RITE_NO_COLOR" ""))

(deftest purple-plain-when-no-color
  (os/setenv "RITE_NO_COLOR" "1")
  (is (= "hello" (style/purple "hello")))
  (os/setenv "RITE_NO_COLOR" ""))

;; ---------------------------------------------------------------------------
;; header builders (assert plain shapes under RITE_NO_COLOR)
;; ---------------------------------------------------------------------------

(deftest header-prefixes-arrow
  (os/setenv "RITE_NO_COLOR" "1")
  (is (= "=> Building bin/app..." (style/header "Building bin/app...")))
  (os/setenv "RITE_NO_COLOR" ""))

(deftest task-header-format
  (os/setenv "RITE_NO_COLOR" "1")
  (is (= "=> Running task ci..." (style/task-header "ci")))
  (os/setenv "RITE_NO_COLOR" ""))

(deftest step-line-prefixes-dollar
  (os/setenv "RITE_NO_COLOR" "1")
  (is (= "$ echo hi" (style/step-line "echo hi")))
  (os/setenv "RITE_NO_COLOR" ""))

(deftest header-is-green-when-color-enabled
  (os/setenv "RITE_NO_COLOR" "")
  (is (= (str esc "[38;5;35m=> hi" esc "[0m") (style/header "hi"))))

(deftest task-header-is-purple-when-color-enabled
  (os/setenv "RITE_NO_COLOR" "")
  (is (= (str esc "[38;5;98m=> Running task t..." esc "[0m")
         (style/task-header "t"))))
