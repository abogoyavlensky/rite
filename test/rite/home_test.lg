;; Unit tests for rite.home.
;; Run with: lgx test  (from project root)

(ns rite.home-test
  (:require [clojure.test :refer [deftest is]]
            [rite.home :as home]
            [rite.path :as path]))

;; os/getenv returns "" for an unset var, and home/root treats a blank value as
;; absent, so each test sets "" to simulate "unset" and restores env afterward.

(deftest root-prefers-rite-home
  (os/setenv "RITE_HOME" "/tmp/rite-home-test")
  (os/setenv "XDG_CACHE_HOME" "/tmp/xdg-cache-test")
  (is (= "/tmp/rite-home-test" (home/root)))
  (os/setenv "RITE_HOME" "")
  (os/setenv "XDG_CACHE_HOME" ""))

(deftest root-falls-back-to-xdg-cache-home
  (os/setenv "RITE_HOME" "")
  (os/setenv "XDG_CACHE_HOME" "/tmp/xdg-cache-test")
  (is (= "/tmp/xdg-cache-test/rite" (home/root)))
  (os/setenv "XDG_CACHE_HOME" ""))

;; The XDG spec requires XDG_CACHE_HOME to be absolute; relative values must
;; be ignored, else the cache lands relative to the current working directory.
(deftest root-ignores-relative-xdg-cache-home
  (os/setenv "RITE_HOME" "")
  (os/setenv "XDG_CACHE_HOME" "relative/cache")
  (is (= (path/join (os/getenv "HOME") ".cache" "rite") (home/root)))
  (os/setenv "XDG_CACHE_HOME" ""))

(deftest root-defaults-to-home-dot-cache-rite
  (os/setenv "RITE_HOME" "")
  (os/setenv "XDG_CACHE_HOME" "")
  (is (= (path/join (os/getenv "HOME") ".cache" "rite") (home/root))))
